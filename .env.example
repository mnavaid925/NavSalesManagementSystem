# Sales Management System — environment configuration
# Copy this file to `.env` and adjust for your machine. `.env` is gitignored.

# --- Django ---
SECRET_KEY=django-insecure-change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# --- Database (MySQL / MariaDB via XAMPP) ---
DB_ENGINE=django.db.backends.mysql
DB_NAME=nav_sms
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Email (dev: prints to console) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@salesmanagement.local
